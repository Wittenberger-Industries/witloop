# Whitelist approach: ignore everything by default...
*

# ...but descend into directories so nested whitelist rules can match...
!*/

# ...then re-include only the plugin's published paths.
!/.claude-plugin/**
!/.codex-plugin/**
!/.github/**
!/skills/**
!/agents/**
!/references/**
!/hooks/**
!/scripts/**
!/docs/**
!/tests/**
!/AGENTS.md
!/README.md
!/.gitignore

# ...but never Python bytecode, even under the whitelisted paths above (regenerated on every run).
__pycache__/
*.pyc

# Local harness state (session settings, worktrees): never part of the plugin.
/.claude/
